# droneci_write_safety.rules
# Technology: droneci | Capability: write

rule droneci-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "privileged: true"
  MESSAGE "Blocked an unsafe pattern in droneci. Use the recommended best practices for 2025/2026."
}

rule droneci-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "drone exec"
  MESSAGE "You are using an outdated API for droneci. Please upgrade to the newer API."
}
